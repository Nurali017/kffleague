# Backend image to run on the dedicated media server
BACKEND_IMAGE=ghcr.io/nurali017/qfl-backend:latest
MEDIA_WORKER_CONTAINER_NAME=qfl-media-worker

# Path on the media server host that contains runtime secrets.
# Must include the Google service account JSON at GOOGLE_SERVICE_ACCOUNT_FILE.
MEDIA_SECRETS_DIR=./secrets-media

# Shared primary infrastructure via local SSH tunnels on the media host
DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:15432/qfl_db
REDIS_URL=redis://127.0.0.1:16379/0
MINIO_ENDPOINT=127.0.0.1:19000
MINIO_PUBLIC_ENDPOINT=kffleague.kz/storage
MINIO_ACCESS_KEY=minio-access-key
MINIO_SECRET_KEY=minio-secret-key
MINIO_BUCKET=qfl-files
MINIO_SECURE=false
DATABASE_POOL_CLASS=null

# Goal-video ingest from Google Drive
GOOGLE_DRIVE_ENABLED=true
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/google-sa.json
GOOGLE_DRIVE_GOALS_FOLDER_ID=
GOAL_VIDEO_AI_FALLBACK_ENABLED=true
GOAL_VIDEO_AI_MODEL=claude-haiku-4-5-20251001
GOAL_VIDEO_SYNC_INTERVAL_MINUTES=2
GOAL_VIDEO_TRANSCODE_ENABLED=true
GOAL_VIDEO_TRANSCODE_CRF=20
GOAL_VIDEO_TRANSCODE_PRESET=medium
# 0 = libx264 auto (all cores). Set to a number if the host is shared.
GOAL_VIDEO_TRANSCODE_THREADS=0

# Needed only when AI fallback stays enabled
ANTHROPIC_API_KEY=

# Goal-video Telegram attach on the media worker
TELEGRAM_PUBLIC_POSTS_ENABLED=true
TELEGRAM_PUBLIC_CHAT_ID=
TELEGRAM_CHAT_ID=
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_SESSION_PATH=/app/secrets/.telethon_qfl_session

# Keep storage object naming and app defaults aligned with prod
CURRENT_SEASON_ID=200
