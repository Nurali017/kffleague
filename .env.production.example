# ============================================================
# QFL Production Environment Configuration
# Copy this to .env and fill in all values
# ============================================================

# ---------- Domain ----------
SITE_DOMAIN=kffleague.kz

# ---------- PostgreSQL ----------
POSTGRES_USER=qfl_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=qfl_db

# ---------- MinIO (S3 Object Storage) ----------
MINIO_ACCESS_KEY=qfl-minio-admin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=qfl-files
MINIO_PUBLIC_ENDPOINT=https://kffleague.kz/storage
MINIO_SECURE=false

# ---------- SOTA API Credentials ----------
SOTA_API_EMAIL=
SOTA_API_PASSWORD=

# ---------- League Configuration ----------
DEFAULT_SEASON_ID=200
DEFAULT_TOUR=1
DEFAULT_LANGUAGE=ru
SYNC_SEASON_IDS=[61,85,71,80,84,200]

# ---------- OpenAI (optional) ----------
OPENAI_API_KEY=

# ---------- Telegram notifications ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFICATIONS_ENABLED=false

# ---------- Cache ----------
CACHE_ENABLED=false

# ---------- Feature flags ----------
CUP_DRAW_ENABLED=true
NEXT_PUBLIC_CUP_DRAW_ENABLED=true

# ---------- SEO & Analytics (build-time, for frontend) ----------
GA_MEASUREMENT_ID=
GOOGLE_SITE_VERIFICATION=
YANDEX_VERIFICATION=

# ---------- Deployment (for GitHub Actions) ----------
DEPLOY_USER=debian
DEPLOY_HOST=kmff.kz
DEPLOY_PATH=/home/debian/qfl
